def create_funnel_structure():
    G6 = nx.Graph()

    nodes_coords = {
        i: (2, 3),
        j: (1, 2),
        k: (3, 2),
        a: (0.5, 4),
        b: (3.5, 4),
        c: (4.5, 2.5),
        d: (2, 0.5),
        e: (-0.5, 2.5),
    }

    edges = [
        # outer ring - the incoming data register (abcde)
        (a, b), (b, c), (c, d), (d, e), (e, a),
        # converging spokes - funneling into ijk hub
        (b, k), (c, k), #(d, j), (e, j), (a, i), 
        # ijk hub tie
        #(i, j),
    ]
    G6.add_nodes_from(nodes_coords.keys())
    G6.add_edges_from(edges)
    nx.draw(G6, pos=nodes_coords, with_labels=True, node_size=700,
             node_color='lightblue', font_size=10, font_color='black')
    plt.title("Funnel Formation of Qubits\n RECEIVE STATE")

create_funnel_structure()

